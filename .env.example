# ─── The Pace Note — environment variables ───────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env` or `.env.local` with real secrets.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Resend (https://resend.com → API Keys). Server-only — do NOT prefix with NEXT_PUBLIC.
RESEND_API_KEY=re_your_resend_api_key

# Used to obfuscate URL params (e.g. order ids in links). NOTE: this is exposed
# to the browser (NEXT_PUBLIC), so it is obfuscation only, NOT real security —
# actual access control is enforced by Supabase RLS. Still, set a random value.
# Generate with: openssl rand -base64 32
NEXT_PUBLIC_URL_SECRET=change-me-to-a-long-random-string
